{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": [
            "ES2022"
        ],
        "types": [
            "node"
        ],
        "rootDir": ".",
        "outDir": "dist/server",
        "noEmit": false,
        "allowImportingTsExtensions": false,
        "isolatedModules": false,
        "noUncheckedSideEffectImports": false
    },
    "include": [
        "server/**/*.ts",
        "src/multiplayer/protocol.ts"
    ]
}
